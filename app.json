{
  "expo": {
    "name": "LocaPic",
    "slug": "locapic",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stephani.locapic"
    },
    "android": {
      "package": "com.stephani.locapic",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "LocaPic butuh akses galeri untuk memilih foto check-in kamu.",
          "cameraPermission": "LocaPic butuh akses kamera untuk mengambil foto check-in kamu."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LocaPic butuh akses lokasi untuk mencatat titik check-in kamu."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3932e48a-c295-4642-a0d5-59c5d5f8a2af"
      }
    },
    "owner": "stephanizz"
  }
}